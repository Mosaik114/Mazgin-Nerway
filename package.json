{
  "name": "mazgin-nerway",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci:check": "npm run lint && npm run validate:content && npm run test && npm run build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "validate:content": "node scripts/validate-content.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "security:audit:prod": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^7.7.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "next": "15.x",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "resend": "^6.10.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@next/bundle-analyzer": "^16.2.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prisma": "^7.7.0",
    "typescript": "^5",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4"
  }
}
