# Auth.js (Google Login + eigene Rollen)
# Sicheren Secret-String generieren mit:
# npx auth secret
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Kommagetrennte Liste fuer den ersten Admin (z. B. ich@beispiel.de,zweit@beispiel.de)
ADMIN_EMAILS=

# Postgres-Verbindung (z. B. Neon)
DATABASE_URL=

# Resend API Key
# Kostenlos holen auf: https://resend.com -> API Keys -> Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-Mail-Adresse, an die Kontaktnachrichten gesendet werden
CONTACT_TO_EMAIL=kontakt@mazginnerway.de
# Absenderadresse fuer Resend (verifizierte Domain empfohlen)
CONTACT_FROM_EMAIL=Kontaktformular <onboarding@resend.dev>

# Pflicht fuer rechtssicheren Live-Betrieb (Impressum)
LEGAL_NAME=Mazgin Nerway
LEGAL_STREET=Strasse und Hausnummer
LEGAL_POSTAL_CODE=12345
LEGAL_CITY=Musterstadt
LEGAL_COUNTRY=Deutschland
LEGAL_EMAIL=kontakt@mazginnerway.de

# Optional: Umami Analytics (wenn beide gesetzt sind, wird Umami geladen)
NEXT_PUBLIC_UMAMI_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Optional: Kontakt-API Rate Limits
CONTACT_RATE_LIMIT_MAX=3
CONTACT_RATE_LIMIT_WINDOW_MS=900000
# Optional empfohlen: eigener Salt fuer gehashte Rate-Limit-Keys
CONTACT_RATE_LIMIT_SALT=

# Optional: Detailzugriff auf /api/health via Header x-health-token
HEALTHCHECK_TOKEN=

# Optional: Server-Logging-Level (debug|info|warn|error)
LOG_LEVEL=info
